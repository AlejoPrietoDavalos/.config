		"pickerGroup.border": "{{ui.accent}}99",
		"pickerGroup.foreground": "{{ui.accent}}99",

		// Integrated Terminal Colors
		"terminal.background": "{{ui.bg.1}}",
		// "terminal.foreground": "",
