		// Button Control
		"button.background": "{{ui.accent}}99",
		// "button.foreground": "",
		// "button.hoverBackground": "",

		// Dropdown Control
		"dropdown.background": "{{ui.bg.1}}",
		// "dropdown.listBackground": "",
		"dropdown.border": "{{ui.accent}}99",
		// "dropdown.foreground": "",

		// Input Control
		"input.background": "{{ui.bg.3}}",
		// "input.border": "",
		"input.foreground": "{{ui.fg.1}}",
		"input.placeholderForeground": "{{ui.fg.1}}AA",
		"inputOption.activeBorder": "{{ui.accent}}99",
		"inputValidation.errorBackground": "",   //"#571b26",
		"inputValidation.errorBorder": "",       //"#a92049",
		"inputValidation.infoBackground": "",    //"#052730",
		"inputValidation.infoBorder": "",        //"#363b5f",
		"inputValidation.warningBackground": "", //"#5d5938",
