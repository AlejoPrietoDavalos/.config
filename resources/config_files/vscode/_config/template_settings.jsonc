		// "activityBar.border": "",
		// "activityBarBadge.background": "",
		// "activityBarBadge.foreground": "",

		// Side Bar
		"sideBar.background": "{{ui.bg.1}}",
		// "sideBar.foreground": "", 	// ---> NOTA: Color del texto del exporador de archivos en la sidebar
		"sideBar.border": "{{ui.bg.2}}",
		// "sideBar.dropBackground": "",
		"sideBarTitle.foreground": "{{ui.fg.1}}",
		"sideBarSectionHeader.background": "{{ui.bg.0}}",
