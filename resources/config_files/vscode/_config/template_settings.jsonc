		"editorGutter.background": "{{ui.bg.2}}",
		// "editorGutter.modifiedBackground": "",
		// "editorGutter.addedBackground": "",
		// "editorGutter.deletedBackground": "",
		"minimap.selectionHighlight": "{{special.text_selection}}",

		// Diff Editor Colors
		// "diffEditor.insertedTextBackground": "",
		// "diffEditor.insertedTextBorder": "",
		// "diffEditor.removedTextBackground": "",
		// "diffEditor.removedTextBorder": "",

		// Editor Widget Colors
		"editorWidget.background": "{{ui.bg.1}}",
		// "editorWidget.border": "",
		// "editorSuggestWidget.background": "",
		// "editorSuggestWidget.border": "",
		// "editorSuggestWidget.foreground": "",
		// "editorSuggestWidget.highlightForeground": "",
		// "editorSuggestWidget.selectedBackground": "",
		"editorHoverWidget.background": "{{ui.bg.4}}",
		// "editorHoverWidget.border": "",
		"debugExceptionWidget.background": "{{ui.bg.1}}",
		"debugExceptionWidget.border": "{{state.error}}",
		// "editorMarkerNavigation.background": "",
		"editorMarkerNavigationError.background": "{{state.error}}",
		"editorMarkerNavigationWarning.background": "{{state.warning}}",
		// "editorMarkerNavigationInfo.background": "",

		// Peek View Colors
		"peekView.border": "{{ui.border}}",
		"peekViewEditor.background": "{{special.peek_bg}}",
		// "peekViewEditorGutter.background": "",
		"peekViewEditor.matchHighlightBackground": "{{special.peek_match}}",
		"peekViewResult.background": "{{ui.bg.1}}",
		// "peekViewResult.fileForeground": "",
