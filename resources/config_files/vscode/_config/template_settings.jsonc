		// "scrollbarSlider.hoverBackground": "",

		// Badge
		// "badge.foreground": "",
		"badge.background": "{{special.badge}}",

		// Progress Bar
		"progressBar.background": "{{special.badge}}",

		// Lists and Trees
		"list.activeSelectionBackground": "{{ui.bg.5}}",
		// "list.activeSelectionForeground": "",
		"list.dropBackground": "{{ui.bg.4}}88",
		// "list.focusBackground": "",
		// "list.focusForeground": "",
		"list.highlightForeground": "{{special.highlight}}",
